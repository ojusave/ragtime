DATABASE_URL=postgresql://ragtime:ragtime@localhost:5432/ragtime
OPENROUTER_API_KEY=
RENDER_API_KEY=
APP_URL=http://localhost:5173
OPENROUTER_APP_TITLE=RAGtime
MODEL_GATEWAY=openrouter
JUDGE_MODEL=
MAX_RUN_BUDGET_USD=5
EMBED_BATCH_SIZE=64
EMBED_FANOUT_BATCH=8
TRIAL_FANOUT_BATCH=12
DB_POOL_MAX=3
MAX_TRIALS_PER_RUN=324
# REVIEW L1 (Low): TRIAL_FANOUT_BATCH and EMBED_FANOUT_BATCH are defined twice in this
# file with different values (lines 10-11 above). Last occurrence wins in typical dotenv
# loaders, so editing the first copy silently does nothing. Keep one entry per variable.
TRIAL_FANOUT_BATCH=8
EMBED_FANOUT_BATCH=6
CHAOS_FAILURE_RATE=0
WORKFLOW_SLUG=ragtime-workflows
