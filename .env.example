DATABASE_URL=postgresql://ragtime:ragtime@localhost:5432/ragtime
OPENROUTER_API_KEY=
RENDER_API_KEY=
# Local dev only: route workflow triggers to `render workflows dev` on :8120.
# Leave RENDER_USE_LOCAL_DEV unset in production so the SDK uses the Render API.
RENDER_USE_LOCAL_DEV=true
RENDER_LOCAL_DEV_URL=http://localhost:8120
APP_URL=http://localhost:5173
OPENROUTER_APP_TITLE=RAGtime
MODEL_GATEWAY=openrouter
# Required: the chat model that scores answers. Runs are rejected without it.
# Use any chat slug you can access, e.g. openai/gpt-4o-mini or openrouter/auto
JUDGE_MODEL=
MAX_RUN_BUDGET_USD=5
MAX_PROVIDER_CALL_USD=0.5
EMBED_BATCH_SIZE=64
# Max parallel subtasks per wave. Keep these low so parallel fan-out does not
# exhaust Postgres connections ("sorry, too many clients already").
DOC_INGEST_FANOUT_BATCH=8
EMBED_FANOUT_BATCH=6
TRIAL_FANOUT_BATCH=8
DB_POOL_MAX=3
MAX_TRIALS_PER_RUN=324
CHAOS_FAILURE_RATE=0
WORKFLOW_SLUG=ragtime-workflows
