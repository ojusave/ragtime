{
  "name": "@ragtime/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm build:client && pnpm build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "dev": "concurrently -n web,api,tasks -c blue,green,yellow \"vite\" \"tsx watch src/server/index.ts\" \"render workflows dev -- pnpm --filter @ragtime/workflows dev\"",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.1.1",
    "@mantine/charts": "^7.17.1",
    "@mantine/core": "^7.17.1",
    "@mantine/dropzone": "^7.17.1",
    "@mantine/hooks": "^7.17.1",
    "@mantine/notifications": "^7.17.1",
    "@ragtime/core": "workspace:*",
    "@ragtime/db": "workspace:*",
    "@ragtime/gateway-fake": "workspace:*",
    "@ragtime/gateway-openrouter": "workspace:*",
    "@renderinc/sdk": "^0.5.0",
    "@tanstack/react-query": "^5.67.2",
    "drizzle-orm": "^0.39.3",
    "fastify": "^5.2.1",
    "papaparse": "^5.5.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^4.12.1",
    "react-router-dom": "^7.3.0",
    "recharts": "^2.15.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vite": "^6.2.1"
  }
}
